{
  "version": "0.2.0",
  "configurations": [
    // ── Next.js web app ────────────────────────────────────────────────────────
    {
      "name": "Next.js: dev server",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/.bin/next",
      "args": ["dev"],
      "cwd": "${workspaceFolder}",
      "env": { "NODE_ENV": "development" },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "name": "Next.js: attach to running dev server",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "urlFilter": "http://localhost:3000/*",
      "webRoot": "${workspaceFolder}"
    },

    // ── Hono server ────────────────────────────────────────────────────────────
    {
      "name": "Server: dev (tsx watch)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--import",
        "tsx/esm",
        "--inspect"
      ],
      "program": "${workspaceFolder}/server/src/index.ts",
      "cwd": "${workspaceFolder}/server",
      "envFile": "${workspaceFolder}/server/.env.example",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "outFiles": ["${workspaceFolder}/server/dist/**/*.js"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/server/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Server: built (node dist/index.js)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/server/dist/index.js",
      "cwd": "${workspaceFolder}/server",
      "envFile": "${workspaceFolder}/server/.env.example",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },

    // ── Electron desktop ───────────────────────────────────────────────────────
    {
      "name": "Electron: main process",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/desktop/node_modules/.bin/electron",
      "runtimeArgs": [
        "--inspect=9229",
        "${workspaceFolder}/desktop/out/main/index.js"
      ],
      "cwd": "${workspaceFolder}/desktop",
      "env": { "ELECTRON_RUN_AS_NODE": "" },
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"],
      "outFiles": ["${workspaceFolder}/desktop/out/**/*.js"],
      "resolveSourceMapLocations": [
        "${workspaceFolder}/desktop/**",
        "!**/node_modules/**"
      ]
    },
    {
      "name": "Electron: renderer (Chrome DevTools)",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "urlFilter": "http://localhost:5173/*",
      "webRoot": "${workspaceFolder}/desktop/src/renderer/src",
      "sourceMapPathOverrides": {
        "/@fs/*": "*",
        "/src/*": "${workspaceFolder}/desktop/src/renderer/src/*"
      }
    }
  ],

  "compounds": [
    {
      "name": "Full stack: Next.js + Server",
      "configurations": ["Next.js: dev server", "Server: dev (tsx watch)"],
      "stopAll": true
    },
    {
      "name": "Electron: main + renderer",
      "configurations": ["Electron: main process", "Electron: renderer (Chrome DevTools)"],
      "stopAll": true,
      "presentation": { "hidden": false, "group": "Desktop" }
    }
  ]
}
