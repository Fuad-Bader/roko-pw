{
  "name": "roko-pw-desktop",
  "version": "0.1.0",
  "description": "RokoPW – Zero-trust password manager",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "electron-vite build && electron-builder",
    "build:dir": "electron-vite build && electron-builder --dir",
    "preview": "node scripts/dev.js --preview"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "cross-env": "^7.0.3",
    "electron": "29.4.6",
    "electron-builder": "^25.1.7",
    "electron-vite": "^2.3.0",
    "react": "^19.2.4",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.0.0",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.1.0",
    "typescript": "^5.7.0"
  },
  "build": {
    "appId": "com.rokopw.desktop",
    "productName": "RokoPW",
    "copyright": "Copyright © 2026",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "icon": "resources/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
