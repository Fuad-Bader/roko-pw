{
  "include": ["src/renderer/src/**/*"],
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/lib/storage": ["./src/renderer/src/lib/storage.ts"],
      "@/lib/*": ["../lib/*"],
      "@/*": ["../*"],
      "@components/*": ["../app/components/*"]
    }
  }
}
